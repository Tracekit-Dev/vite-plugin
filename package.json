{
  "name": "@tracekit/vite-plugin",
  "version": "0.1.1",
  "description": "TraceKit source map upload plugin for Vite",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "vite": "^4.0.0 || ^5.0.0 || ^6.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "vite": "^5.0.0"
  },
  "keywords": [
    "vite",
    "plugin",
    "sourcemap",
    "source-map",
    "tracekit",
    "apm",
    "debugging"
  ],
  "license": "MIT"
}
